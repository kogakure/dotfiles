                "hostname": "allow",
                "whoami": "allow",
                "which *": "allow",
                "realpath *": "allow"
              }
            }
          }
        },
        "permission": {
          "webfetch": "deny",
          "worktree_*": "deny"
        }
      }
    }
  }
}