{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*.key": "deny",
      "*.pem": "deny",
      "id_rsa*": "deny",
      "secrets.*": "deny",
      "credentials.*": "deny"
    },
    "edit": "allow",
    "external_directory": {
      "*": "deny"
    },
    "webfetch": "allow",
    "bash": {
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "*": "ask",
      "sudo *": "deny",
      "su *": "deny",
      "dd *": "deny",
      "mkfs *": "deny",
      "rm -rf /*": "deny",
      "> /dev/*": "deny",
      "chmod -R *": "deny",
      "chown *": "deny",
      "chgrp *": "deny",
      "printenv*": "deny",
      "env*": "deny",
      "export*": "deny",
      "curl *": "ask",
      "wget *": "ask",
      "nc *": "deny",
      "scp *": "deny",
      "ssh *": "deny",
      "ftp *": "deny",
      "telnet *": "deny",
      "nmap *": "deny",
      "git push*": "ask",
      "npm install *": "ask",
      "npm i *": "ask",
      "yarn add *": "ask",
      "pip install *": "ask",
      "pip3 install *": "ask"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
      "type": "local"
    },
    "open-meteo": {
      "command": ["npx", "-y", "-p", "open-meteo-mcp-server", "open-meteo-mcp-server"],
      "type": "local"
    }
  },
  "plugin": [],
  "provider": {
    "ollama": {
      "models": {},
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
