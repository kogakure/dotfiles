{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/gemma4:31b-cloud",
  "default_agent": "plan",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rmdir *": "ask",
      "git push *": "ask",
      "git checkout *": "ask"
    }
  },
  "provider": {},
  "plugin": [],
  "mcp": {
    "open-meteo": {
      "type": "local",
      "command": ["npx", "-y", "-p", "open-meteo-mcp-server", "open-meteo-mcp-server"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"]
    }
  },
  "instructions": ["https://opencode.school/api/progress/extra-hacker-8940"]
}
