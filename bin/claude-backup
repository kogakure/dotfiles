#!/bin/bash

# claude-backup
# Backs up Claude Code configuration to private/ submodule
# Each profile (work or personal) is fully isolated — no shared/ directory.
#
# Usage: claude-backup
# Reads ~/.agentic-profile, falling back to legacy ~/.machine-profile.
# Set with: agentic-set-profile work|personal

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

CLAUDE_DIR="$HOME/.claude"
DOTFILES="$HOME/.dotfiles"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

PROFILE=$(cat "$HOME/.agentic-profile" 2>/dev/null || cat "$HOME/.machine-profile" 2>/dev/null || echo "personal")
PROFILE_DIR="$DOTFILES/private/claude/$PROFILE"
LEGACY_SHARED="$DOTFILES/private/claude/shared"

echo -e "${GREEN}Starting Claude Code backup...${NC}"
echo -e "Profile: ${YELLOW}$PROFILE${NC}"

# Remove legacy shared/ if present
if [ -d "$LEGACY_SHARED" ]; then
    echo -e "${YELLOW}Legacy shared/ directory found: $LEGACY_SHARED${NC}"
    read -p "Delete it? All content moves to per-profile dirs from now on. (y/N) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rf "$LEGACY_SHARED"
        echo -e "  ✓ Deleted: $LEGACY_SHARED"
    else
        echo -e "  ${YELLOW}Skipped deletion — shared/ still exists.${NC}"
    fi
fi

mkdir -p "$PROFILE_DIR"

backup_file() {
    local src="$1"
    local dest="$2"

    if [ -f "$src" ]; then
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        echo -e "  ✓ Backed up: $(basename "$src")"
    else
        echo -e "  ${YELLOW}⊗ Not found: $(basename "$src")${NC}"
    fi
}

backup_dir() {
    local src="$1"
    local dest="$2"

    if [ -d "$src" ] && [ "$(ls -A "$src" 2>/dev/null)" ]; then
        mkdir -p "$(dirname "$dest")"
        rsync -a --delete "$src/" "$dest/"
        echo -e "  ✓ Backed up: $(basename "$src")/ ($(find "$src" -type f | wc -l | tr -d ' ') files)"
    else
        echo -e "  ${YELLOW}⊗ Not found or empty: $(basename "$src")/${NC}"
    fi
}

# ── Settings & identity ───────────────────────────────────────────────────────

echo ""
echo "Backing up settings..."
backup_file "$CLAUDE_DIR/CLAUDE.md"          "$PROFILE_DIR/CLAUDE.md"
backup_file "$CLAUDE_DIR/RTK.md"             "$PROFILE_DIR/RTK.md"
backup_file "$CLAUDE_DIR/settings.json"      "$PROFILE_DIR/settings.json"
backup_file "$CLAUDE_DIR/keybindings.json"   "$PROFILE_DIR/keybindings.json"
backup_file "$CLAUDE_DIR/mcp-needs-auth-cache.json" "$PROFILE_DIR/mcp-needs-auth-cache.json"
backup_file "$CLAUDE_DIR/policy-limits.json" "$PROFILE_DIR/policy-limits.json"

# ── Commands, scripts, hooks, skills ─────────────────────────────────────────

echo ""
echo "Backing up commands, scripts, hooks & skills..."
backup_dir "$CLAUDE_DIR/commands" "$PROFILE_DIR/commands"
backup_dir "$CLAUDE_DIR/scripts"  "$PROFILE_DIR/scripts"
backup_dir "$CLAUDE_DIR/hooks"    "$PROFILE_DIR/hooks"
backup_dir "$CLAUDE_DIR/skills"   "$PROFILE_DIR/skills"

# ── Plugins ───────────────────────────────────────────────────────────────────

echo ""
echo "Backing up plugins configuration..."
backup_file "$CLAUDE_DIR/plugins/known_marketplaces.json" "$PROFILE_DIR/plugins/known_marketplaces.json"

# ── Profile-specific state ────────────────────────────────────────────────────

echo ""
echo "Backing up profile state..."
backup_file "$HOME/.claude.json"             "$PROFILE_DIR/.claude.json"
backup_file "$CLAUDE_DIR/history.jsonl"      "$PROFILE_DIR/history.jsonl"
backup_file "$CLAUDE_DIR/stats-cache.json"   "$PROFILE_DIR/stats-cache.json"

# ── Projects ─────────────────────────────────────────────────────────────────

echo ""
echo "Backing up project configurations..."
if [ -d "$CLAUDE_DIR/projects" ]; then
    for project_dir in "$CLAUDE_DIR/projects"/*; do
        if [ -d "$project_dir" ]; then
            project_name=$(basename "$project_dir")

            if [ -f "$project_dir/.claude.json" ]; then
                backup_file "$project_dir/.claude.json" "$PROFILE_DIR/projects/$project_name/.claude.json"
            fi

            if [ -f "$project_dir/CLAUDE.md" ]; then
                backup_file "$project_dir/CLAUDE.md" "$PROFILE_DIR/projects/$project_name/CLAUDE.md"
            fi

            if [ -d "$project_dir/memory" ] && [ "$(ls -A "$project_dir/memory" 2>/dev/null)" ]; then
                backup_dir "$project_dir/memory" "$PROFILE_DIR/projects/$project_name/memory"
            fi

            if [ -f "$project_dir/hooks.json" ]; then
                backup_file "$project_dir/hooks.json" "$PROFILE_DIR/projects/$project_name/hooks.json"
            fi
        fi
    done
fi

# ── Plans ─────────────────────────────────────────────────────────────────────

echo ""
echo "Backing up plans..."
backup_dir "$CLAUDE_DIR/plans" "$PROFILE_DIR/plans"

# ── Shell snapshots (latest 5) ────────────────────────────────────────────────

echo ""
echo "Backing up shell snapshots..."
if [ -d "$CLAUDE_DIR/shell-snapshots" ] && [ "$(ls -A "$CLAUDE_DIR/shell-snapshots" 2>/dev/null)" ]; then
    mkdir -p "$PROFILE_DIR/shell-snapshots"
    ls -t "$CLAUDE_DIR/shell-snapshots" | head -5 | while read -r file; do
        cp "$CLAUDE_DIR/shell-snapshots/$file" "$PROFILE_DIR/shell-snapshots/"
    done
    echo -e "  ✓ Backed up: shell-snapshots/ (latest 5 snapshots)"
else
    echo -e "  ${YELLOW}⊗ Not found or empty: shell-snapshots/${NC}"
fi

# ── Manifest ─────────────────────────────────────────────────────────────────

echo ""
echo "Creating backup manifest..."
cat > "$PROFILE_DIR/BACKUP_INFO.txt" <<EOF
Claude Code Backup
==================
Timestamp:  $TIMESTAMP
Hostname:   $(hostname)
Profile:    $PROFILE
Claude Dir: $CLAUDE_DIR

Backed up:
- CLAUDE.md, RTK.md, settings.json, keybindings.json
- mcp-needs-auth-cache.json, policy-limits.json
- commands/, scripts/, hooks/, skills/
- plugins/known_marketplaces.json
- .claude.json (auth)
- history.jsonl, stats-cache.json
- Project configs (.claude.json, CLAUDE.md, memory/, hooks.json)
- plans/
- Recent shell snapshots (last 5)

Excluded (large / transient):
- projects/**/*.jsonl (conversation history)
- cache/, telemetry/, file-history/, session-env/, sessions/, backups/
- settings.json.bak, .caveman-active, .last-cleanup
EOF

echo -e "${GREEN}✓ Backup complete!${NC}"
echo -e "  Profile dir: $PROFILE_DIR"
echo ""
echo "To restore on another machine, run: claude-restore"
