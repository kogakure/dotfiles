#!/bin/bash

# claude-backup
# Backs up Claude Code configuration to private/ submodule
# Splits into shared/ (all machines) and profile-specific/ (work or private)
#
# Usage: claude-backup
# Requires: ~/.machine-profile containing "work" or "private"
# Set with: claude-set-profile work|private

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Directories
CLAUDE_DIR="$HOME/.claude"
DOTFILES="$HOME/.dotfiles"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Profile detection
PROFILE=$(cat "$HOME/.machine-profile" 2>/dev/null || echo "private")
SHARED_DIR="$DOTFILES/private/claude/shared"
PROFILE_DIR="$DOTFILES/private/claude/$PROFILE"

echo -e "${GREEN}Starting Claude Code backup...${NC}"
echo -e "Profile: ${YELLOW}$PROFILE${NC}"

mkdir -p "$SHARED_DIR" "$PROFILE_DIR"

# Function to backup a file if it exists
backup_file() {
    local src="$1"
    local dest="$2"

    if [ -f "$src" ]; then
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        echo -e "  ✓ Backed up: $(basename "$src")"
    else
        echo -e "  ${YELLOW}⊗ Not found: $(basename "$src")${NC}"
    fi
}

# Function to backup a directory if it exists
backup_dir() {
    local src="$1"
    local dest="$2"

    if [ -d "$src" ] && [ "$(ls -A "$src" 2>/dev/null)" ]; then
        mkdir -p "$(dirname "$dest")"
        rsync -a --delete "$src/" "$dest/"
        echo -e "  ✓ Backed up: $(basename "$src")/ ($(find "$src" -type f | wc -l | tr -d ' ') files)"
    else
        echo -e "  ${YELLOW}⊗ Not found or empty: $(basename "$src")/${NC}"
    fi
}

# ── Shared (same across all machines) ────────────────────────────────────────

echo ""
echo "Backing up shared settings..."
backup_file "$CLAUDE_DIR/CLAUDE.md" "$SHARED_DIR/CLAUDE.md"
backup_file "$CLAUDE_DIR/settings.json" "$SHARED_DIR/settings.json"
backup_file "$CLAUDE_DIR/keybindings.json" "$SHARED_DIR/keybindings.json"

echo ""
echo "Backing up shared commands, scripts & hooks..."
backup_dir "$CLAUDE_DIR/commands" "$SHARED_DIR/commands"
backup_dir "$CLAUDE_DIR/scripts" "$SHARED_DIR/scripts"
backup_dir "$CLAUDE_DIR/hooks" "$SHARED_DIR/hooks"
backup_file "$CLAUDE_DIR/RTK.md" "$SHARED_DIR/RTK.md"

echo ""
echo "Backing up shared plugins configuration..."
backup_file "$CLAUDE_DIR/plugins/known_marketplaces.json" "$SHARED_DIR/plugins/known_marketplaces.json"

# ── Profile-specific ─────────────────────────────────────────────────────────

echo ""
echo "Backing up profile-specific settings ($PROFILE)..."
backup_file "$HOME/.claude.json" "$PROFILE_DIR/.claude.json"
backup_file "$CLAUDE_DIR/history.jsonl" "$PROFILE_DIR/history.jsonl"
backup_file "$CLAUDE_DIR/stats-cache.json" "$PROFILE_DIR/stats-cache.json"

echo ""
echo "Backing up project configurations ($PROFILE)..."
if [ -d "$CLAUDE_DIR/projects" ]; then
    for project_dir in "$CLAUDE_DIR/projects"/*; do
        if [ -d "$project_dir" ]; then
            project_name=$(basename "$project_dir")

            if [ -f "$project_dir/.claude.json" ]; then
                backup_file "$project_dir/.claude.json" "$PROFILE_DIR/projects/$project_name/.claude.json"
            fi

            if [ -f "$project_dir/CLAUDE.md" ]; then
                backup_file "$project_dir/CLAUDE.md" "$PROFILE_DIR/projects/$project_name/CLAUDE.md"
            fi

            if [ -d "$project_dir/memory" ] && [ "$(ls -A "$project_dir/memory" 2>/dev/null)" ]; then
                backup_dir "$project_dir/memory" "$PROFILE_DIR/projects/$project_name/memory"
            fi

            if [ -f "$project_dir/hooks.json" ]; then
                backup_file "$project_dir/hooks.json" "$PROFILE_DIR/projects/$project_name/hooks.json"
            fi
        fi
    done
fi

echo ""
echo "Backing up plans ($PROFILE)..."
backup_dir "$CLAUDE_DIR/plans" "$PROFILE_DIR/plans"

echo ""
echo "Backing up shell snapshots ($PROFILE)..."
if [ -d "$CLAUDE_DIR/shell-snapshots" ] && [ "$(ls -A "$CLAUDE_DIR/shell-snapshots" 2>/dev/null)" ]; then
    mkdir -p "$PROFILE_DIR/shell-snapshots"
    ls -t "$CLAUDE_DIR/shell-snapshots" | head -5 | while read -r file; do
        cp "$CLAUDE_DIR/shell-snapshots/$file" "$PROFILE_DIR/shell-snapshots/"
    done
    echo -e "  ✓ Backed up: shell-snapshots/ (latest 5 snapshots)"
else
    echo -e "  ${YELLOW}⊗ Not found or empty: shell-snapshots/${NC}"
fi

# ── Manifest ──────────────────────────────────────────────────────────────────

echo ""
echo "Creating backup manifest..."
cat > "$PROFILE_DIR/BACKUP_INFO.txt" <<EOF
Claude Code Backup
==================
Timestamp: $TIMESTAMP
Hostname:  $(hostname)
Profile:   $PROFILE
Claude Dir: $CLAUDE_DIR

Backed up (shared):
- settings.json, keybindings.json, CLAUDE.md, RTK.md
- commands/, scripts/, hooks/
- plugins/known_marketplaces.json

Backed up (profile: $PROFILE):
- .claude.json (auth)
- history.jsonl, stats-cache.json
- Project configs (.claude.json, CLAUDE.md, memory, hooks)
- plans/
- Recent shell snapshots (last 5)

Note: Conversation history (.jsonl in projects/) and debug logs
are excluded to keep backup size manageable.
EOF

echo -e "${GREEN}✓ Backup complete!${NC}"
echo -e "  Shared:  $SHARED_DIR"
echo -e "  Profile: $PROFILE_DIR"
echo ""
echo "To restore on another machine, run: claude-restore"
