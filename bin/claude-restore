#!/bin/bash

# claude-restore
# Restores Claude Code configuration from private/ submodule backup
# Merges shared/ config with profile-specific (work or private) config
#
# Usage: claude-restore
# Requires: ~/.machine-profile containing "work" or "private"
# Set with: claude-set-profile work|private

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Directories
CLAUDE_DIR="$HOME/.claude"
DOTFILES="$HOME/.dotfiles"

# Profile detection
PROFILE=$(cat "$HOME/.machine-profile" 2>/dev/null || echo "private")
SHARED_DIR="$DOTFILES/private/claude/shared"
PROFILE_DIR="$DOTFILES/private/claude/$PROFILE"

echo -e "${GREEN}Starting Claude Code restore...${NC}"
echo -e "Profile: ${YELLOW}$PROFILE${NC}"

# Check that backup directories exist
if [ ! -d "$SHARED_DIR" ] && [ ! -d "$PROFILE_DIR" ]; then
    echo -e "${RED}Error: No backup found at $DOTFILES/private/claude/${NC}"
    echo "Run claude-backup first or ensure the private submodule is initialized."
    exit 1
fi

# Display backup info if available
if [ -f "$PROFILE_DIR/BACKUP_INFO.txt" ]; then
    echo ""
    echo -e "${YELLOW}Backup Information:${NC}"
    cat "$PROFILE_DIR/BACKUP_INFO.txt"
    echo ""
fi

# Prompt for confirmation
read -p "Do you want to restore Claude Code settings from backup? (y/N) " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Restore cancelled."
    exit 0
fi

mkdir -p "$CLAUDE_DIR"

# Function to restore a file if it exists in backup
restore_file() {
    local src="$1"
    local dest="$2"

    if [ -f "$src" ]; then
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        echo -e "  ✓ Restored: $(basename "$dest")"
    else
        echo -e "  ${YELLOW}⊗ Not in backup: $(basename "$dest")${NC}"
    fi
}

# Function to restore a directory if it exists in backup
restore_dir() {
    local src="$1"
    local dest="$2"

    if [ -d "$src" ] && [ "$(ls -A "$src" 2>/dev/null)" ]; then
        mkdir -p "$dest"
        rsync -a "$src/" "$dest/"
        echo -e "  ✓ Restored: $(basename "$dest")/ ($(find "$src" -type f | wc -l | tr -d ' ') files)"
    else
        echo -e "  ${YELLOW}⊗ Not in backup: $(basename "$dest")/${NC}"
    fi
}

# ── Shared ────────────────────────────────────────────────────────────────────

echo ""
echo "Restoring shared settings..."
restore_file "$SHARED_DIR/CLAUDE.md" "$CLAUDE_DIR/CLAUDE.md"
restore_file "$SHARED_DIR/settings.json" "$CLAUDE_DIR/settings.json"
restore_file "$SHARED_DIR/keybindings.json" "$CLAUDE_DIR/keybindings.json"

echo ""
echo "Restoring shared commands, scripts & hooks..."
restore_dir "$SHARED_DIR/commands" "$CLAUDE_DIR/commands"
restore_dir "$SHARED_DIR/scripts" "$CLAUDE_DIR/scripts"
restore_dir "$SHARED_DIR/hooks" "$CLAUDE_DIR/hooks"
restore_file "$SHARED_DIR/RTK.md" "$CLAUDE_DIR/RTK.md"

echo ""
echo "Restoring shared plugins configuration..."
restore_file "$SHARED_DIR/plugins/known_marketplaces.json" "$CLAUDE_DIR/plugins/known_marketplaces.json"

# ── Profile-specific ─────────────────────────────────────────────────────────

echo ""
echo "Restoring profile-specific settings ($PROFILE)..."
restore_file "$PROFILE_DIR/.claude.json" "$HOME/.claude.json"
restore_file "$PROFILE_DIR/history.jsonl" "$CLAUDE_DIR/history.jsonl"
restore_file "$PROFILE_DIR/stats-cache.json" "$CLAUDE_DIR/stats-cache.json"

echo ""
echo "Restoring project configurations ($PROFILE)..."
if [ -d "$PROFILE_DIR/projects" ]; then
    for project_backup in "$PROFILE_DIR/projects"/*; do
        if [ -d "$project_backup" ]; then
            project_name=$(basename "$project_backup")

            if [ -f "$project_backup/.claude.json" ]; then
                restore_file "$project_backup/.claude.json" "$CLAUDE_DIR/projects/$project_name/.claude.json"
            fi

            if [ -f "$project_backup/CLAUDE.md" ]; then
                restore_file "$project_backup/CLAUDE.md" "$CLAUDE_DIR/projects/$project_name/CLAUDE.md"
            fi

            if [ -d "$project_backup/memory" ]; then
                restore_dir "$project_backup/memory" "$CLAUDE_DIR/projects/$project_name/memory"
            fi

            if [ -f "$project_backup/hooks.json" ]; then
                restore_file "$project_backup/hooks.json" "$CLAUDE_DIR/projects/$project_name/hooks.json"
            fi
        fi
    done
fi

echo ""
echo "Restoring plans ($PROFILE)..."
restore_dir "$PROFILE_DIR/plans" "$CLAUDE_DIR/plans"

echo ""
echo "Restoring shell snapshots ($PROFILE)..."
restore_dir "$PROFILE_DIR/shell-snapshots" "$CLAUDE_DIR/shell-snapshots"

echo ""
echo -e "${GREEN}✓ Restore complete!${NC}"
echo ""
echo "Claude Code settings restored from profile: $PROFILE"
echo "Restart Claude Code to apply all settings."
