#!/bin/bash

# claude-restore
# Restores Claude Code configuration from private/ submodule backup
# Each profile (work or personal) is fully isolated — no shared/ directory.
#
# Usage: claude-restore
# Reads ~/.agentic-profile, falling back to legacy ~/.machine-profile.
# Set with: agentic-set-profile work|personal

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

CLAUDE_DIR="$HOME/.claude"
DOTFILES="$HOME/.dotfiles"

PROFILE=$(cat "$HOME/.agentic-profile" 2>/dev/null || cat "$HOME/.machine-profile" 2>/dev/null || echo "personal")
PROFILE_DIR="$DOTFILES/private/claude/$PROFILE"

echo -e "${GREEN}Starting Claude Code restore...${NC}"
echo -e "Profile: ${YELLOW}$PROFILE${NC}"

if [ ! -d "$PROFILE_DIR" ]; then
    echo -e "${RED}Error: No backup found at $PROFILE_DIR${NC}"
    echo "Run claude-backup first or ensure the private/ submodule is initialized."
    exit 1
fi

if [ -f "$PROFILE_DIR/BACKUP_INFO.txt" ]; then
    echo ""
    echo -e "${YELLOW}Backup Information:${NC}"
    cat "$PROFILE_DIR/BACKUP_INFO.txt"
    echo ""
fi

read -p "Do you want to restore Claude Code settings from backup? (y/N) " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Restore cancelled."
    exit 0
fi

# ── Overwrite conflict check ──────────────────────────────────────────────────

conflict_count=0
conflict_samples=()

check_conflict_file() {
    local src="$1"
    local dest="$2"
    if [ -f "$src" ] && [ -f "$dest" ]; then
        conflict_count=$((conflict_count + 1))
        if [ ${#conflict_samples[@]} -lt 5 ]; then
            conflict_samples+=("$dest")
        fi
    fi
}

check_conflict_file "$PROFILE_DIR/.claude.json"                    "$HOME/.claude.json"
check_conflict_file "$PROFILE_DIR/CLAUDE.md"                       "$CLAUDE_DIR/CLAUDE.md"
check_conflict_file "$PROFILE_DIR/RTK.md"                          "$CLAUDE_DIR/RTK.md"
check_conflict_file "$PROFILE_DIR/settings.json"                   "$CLAUDE_DIR/settings.json"
check_conflict_file "$PROFILE_DIR/keybindings.json"                "$CLAUDE_DIR/keybindings.json"
check_conflict_file "$PROFILE_DIR/mcp-needs-auth-cache.json"       "$CLAUDE_DIR/mcp-needs-auth-cache.json"
check_conflict_file "$PROFILE_DIR/policy-limits.json"              "$CLAUDE_DIR/policy-limits.json"
check_conflict_file "$PROFILE_DIR/history.jsonl"                   "$CLAUDE_DIR/history.jsonl"
check_conflict_file "$PROFILE_DIR/stats-cache.json"                "$CLAUDE_DIR/stats-cache.json"
check_conflict_file "$PROFILE_DIR/plugins/known_marketplaces.json" "$CLAUDE_DIR/plugins/known_marketplaces.json"

if [ "$conflict_count" -gt 0 ]; then
    echo -e "${YELLOW}$conflict_count existing file(s) will be overwritten. Examples:${NC}"
    for sample in "${conflict_samples[@]}"; do
        echo -e "  $sample"
    done
    read -p "Continue? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Restore cancelled."
        exit 0
    fi
fi

mkdir -p "$CLAUDE_DIR"

restore_file() {
    local src="$1"
    local dest="$2"

    if [ -f "$src" ]; then
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        echo -e "  ✓ Restored: $(basename "$dest")"
    else
        echo -e "  ${YELLOW}⊗ Not in backup: $(basename "$dest")${NC}"
    fi
}

restore_dir() {
    local src="$1"
    local dest="$2"

    if [ -d "$src" ] && [ "$(ls -A "$src" 2>/dev/null)" ]; then
        mkdir -p "$dest"
        rsync -a "$src/" "$dest/"
        echo -e "  ✓ Restored: $(basename "$dest")/ ($(find "$src" -type f | wc -l | tr -d ' ') files)"
    else
        echo -e "  ${YELLOW}⊗ Not in backup: $(basename "$dest")/${NC}"
    fi
}

# ── Settings & identity ───────────────────────────────────────────────────────

echo ""
echo "Restoring settings..."
restore_file "$PROFILE_DIR/CLAUDE.md"          "$CLAUDE_DIR/CLAUDE.md"
restore_file "$PROFILE_DIR/RTK.md"             "$CLAUDE_DIR/RTK.md"
restore_file "$PROFILE_DIR/settings.json"      "$CLAUDE_DIR/settings.json"
restore_file "$PROFILE_DIR/keybindings.json"   "$CLAUDE_DIR/keybindings.json"
restore_file "$PROFILE_DIR/mcp-needs-auth-cache.json" "$CLAUDE_DIR/mcp-needs-auth-cache.json"
restore_file "$PROFILE_DIR/policy-limits.json" "$CLAUDE_DIR/policy-limits.json"

# ── Commands, scripts, hooks, skills ─────────────────────────────────────────

echo ""
echo "Restoring commands, scripts, hooks & skills..."
restore_dir "$PROFILE_DIR/commands" "$CLAUDE_DIR/commands"
restore_dir "$PROFILE_DIR/scripts"  "$CLAUDE_DIR/scripts"
restore_dir "$PROFILE_DIR/hooks"    "$CLAUDE_DIR/hooks"
restore_dir "$PROFILE_DIR/skills"   "$CLAUDE_DIR/skills"

# ── Plugins ───────────────────────────────────────────────────────────────────

echo ""
echo "Restoring plugins configuration..."
restore_file "$PROFILE_DIR/plugins/known_marketplaces.json" "$CLAUDE_DIR/plugins/known_marketplaces.json"

# ── Profile-specific state ────────────────────────────────────────────────────

echo ""
echo "Restoring profile state..."
restore_file "$PROFILE_DIR/.claude.json"           "$HOME/.claude.json"
restore_file "$PROFILE_DIR/history.jsonl"          "$CLAUDE_DIR/history.jsonl"
restore_file "$PROFILE_DIR/stats-cache.json"       "$CLAUDE_DIR/stats-cache.json"

# ── Projects ─────────────────────────────────────────────────────────────────

echo ""
echo "Restoring project configurations..."
if [ -d "$PROFILE_DIR/projects" ]; then
    for project_backup in "$PROFILE_DIR/projects"/*; do
        if [ -d "$project_backup" ]; then
            project_name=$(basename "$project_backup")

            if [ -f "$project_backup/.claude.json" ]; then
                restore_file "$project_backup/.claude.json" "$CLAUDE_DIR/projects/$project_name/.claude.json"
            fi

            if [ -f "$project_backup/CLAUDE.md" ]; then
                restore_file "$project_backup/CLAUDE.md" "$CLAUDE_DIR/projects/$project_name/CLAUDE.md"
            fi

            if [ -d "$project_backup/memory" ]; then
                restore_dir "$project_backup/memory" "$CLAUDE_DIR/projects/$project_name/memory"
            fi

            if [ -f "$project_backup/hooks.json" ]; then
                restore_file "$project_backup/hooks.json" "$CLAUDE_DIR/projects/$project_name/hooks.json"
            fi
        fi
    done
fi

# ── Plans ─────────────────────────────────────────────────────────────────────

echo ""
echo "Restoring plans..."
restore_dir "$PROFILE_DIR/plans" "$CLAUDE_DIR/plans"

# ── Shell snapshots ───────────────────────────────────────────────────────────

echo ""
echo "Restoring shell snapshots..."
restore_dir "$PROFILE_DIR/shell-snapshots" "$CLAUDE_DIR/shell-snapshots"

echo ""
echo -e "${GREEN}✓ Restore complete!${NC}"
echo ""
echo "Claude Code settings restored from profile: $PROFILE"
echo "Restart Claude Code to apply all settings."
