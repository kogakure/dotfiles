#!/bin/bash

# Ask for the administrator password upfront
sudo -v

# Keep-alive: update existing `sudo` time stamp until script has finished
while true; do
    sudo -n true
    sleep 30
    kill -0 "$$" || exit
done 2>/dev/null &

cd ~/.dotfiles

# Update Homebrew
NONINTERACTIVE=1 brew update
brew outdated
NONINTERACTIVE=1 brew upgrade
brew cleanup

# Ruby
gem update --system --no-document
gem update --no-document
gem cleanup all

# Update tmux plugins
~/.tmux/plugins/tpm/bin/update_plugins all

# Update GitHub extensions
gh extension upgrade --all

# Update Fish plugins
fisher update

# Update Neovim
nvim --headless "+Lazy! sync" +qa

# Maintenance
mo clean
mo optimize

# Update macOS software
sudo softwareupdate -i -a

# Claude
claude-backup

# Write Homebrew Brewfile
homebrew-backup

# Write preferences
preferences-backup

# Write launch agents
launchagents-backup
