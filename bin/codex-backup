#!/bin/bash

# codex-backup
# Backs up durable Codex configuration to the private/ submodule.
# Runtime state, credentials, bundled skills, and caches are intentionally excluded.
#
# Usage: codex-backup
# Reads ~/.agentic-profile, falling back to legacy ~/.machine-profile.
# Set with: agentic-set-profile work|personal

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

CODEX_DIR="${CODEX_HOME:-$HOME/.codex}"
DOTFILES="$HOME/.dotfiles"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

PROFILE=$(cat "$HOME/.agentic-profile" 2>/dev/null || cat "$HOME/.machine-profile" 2>/dev/null || echo "personal")
PROFILE_DIR="$DOTFILES/private/codex/$PROFILE"

echo -e "${GREEN}Starting Codex configuration backup...${NC}"
echo -e "Profile: ${YELLOW}$PROFILE${NC}"
echo -e "Codex home: ${YELLOW}$CODEX_DIR${NC}"

mkdir -p "$PROFILE_DIR"

backup_file() {
    local src="$1"
    local dest="$2"

    if [ -f "$src" ]; then
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        echo -e "  ✓ Backed up: $(basename "$src")"
    else
        rm -f "$dest"
        echo -e "  ${YELLOW}⊗ Not found: $(basename "$src")${NC}"
    fi
}

backup_dir() {
    local src="$1"
    local dest="$2"

    if [ -d "$src" ] && [ "$(ls -A "$src" 2>/dev/null)" ]; then
        mkdir -p "$dest"
        rsync -a --delete "$src/" "$dest/"
        echo -e "  ✓ Backed up: $(basename "$src")/ ($(find "$src" -type f | wc -l | tr -d ' ') files)"
    else
        rm -rf "$dest"
        echo -e "  ${YELLOW}⊗ Not found or empty: $(basename "$src")/${NC}"
    fi
}

echo ""
echo "Backing up settings and global instructions..."
backup_file "$CODEX_DIR/config.toml" "$PROFILE_DIR/config.toml"
if [ -f "$PROFILE_DIR/config.toml" ] && ! grep -Eq '^[[:space:]]*personality[[:space:]]*=' "$PROFILE_DIR/config.toml"; then
    {
        echo 'personality = "friendly"'
        cat "$PROFILE_DIR/config.toml"
    } > "$PROFILE_DIR/config.toml.tmp"
    mv "$PROFILE_DIR/config.toml.tmp" "$PROFILE_DIR/config.toml"
    echo -e "  ✓ Recorded current default personality: friendly"
fi
backup_file "$CODEX_DIR/AGENTS.md" "$PROFILE_DIR/AGENTS.md"
backup_file "$CODEX_DIR/AGENTS.override.md" "$PROFILE_DIR/AGENTS.override.md"
backup_file "$CODEX_DIR/hooks.json" "$PROFILE_DIR/hooks.json"
backup_dir "$CODEX_DIR/rules" "$PROFILE_DIR/rules"

echo ""
echo "Backing up user-installed skills..."
if [ -d "$CODEX_DIR/skills" ]; then
    mkdir -p "$PROFILE_DIR/skills"
    rsync -a --delete --exclude='.system/' "$CODEX_DIR/skills/" "$PROFILE_DIR/skills/"
    echo -e "  ✓ Backed up: skills/ (bundled .system/ excluded)"
else
    rm -rf "$PROFILE_DIR/skills"
    echo -e "  ${YELLOW}⊗ Not found: skills/${NC}"
fi

echo ""
echo "Creating backup manifest..."
cat > "$PROFILE_DIR/BACKUP_INFO.txt" <<EOF
Codex Configuration Backup
==========================
Timestamp:  $TIMESTAMP
Hostname:   $(hostname)
Profile:    $PROFILE
Codex Home: $CODEX_DIR

Backed up:
- config.toml (model, personality, UI, MCP servers, plugins, permissions)
- AGENTS.md and AGENTS.override.md (global instructions)
- hooks.json and rules/
- User-installed skills (bundled .system/ skills excluded)

Excluded (credentials, generated, large, or machine-local state):
- auth.json, installation_id
- .codex-global-state.json, .personality_migration
- history.jsonl, sessions/, archived_sessions/, session_index.jsonl
- *.sqlite, *.sqlite-shm, *.sqlite-wal, sqlite/
- plugins/, vendor_imports/, cache/, .tmp/, models_cache.json
- logs, shell snapshots, computer-use/

After restoring, sign in to Codex and restart the app or CLI.
EOF

echo -e "${GREEN}✓ Backup complete!${NC}"
echo -e "  Profile dir: $PROFILE_DIR"
echo ""
echo "To restore on another machine, run: codex-restore"
