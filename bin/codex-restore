#!/bin/bash

# codex-restore
# Restores durable Codex configuration from the private/ submodule.
#
# Usage: codex-restore [source-profile]
# Reads ~/.agentic-profile, falling back to legacy ~/.machine-profile.
# Set with: agentic-set-profile work|personal

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

CODEX_DIR="${CODEX_HOME:-$HOME/.codex}"
DOTFILES="$HOME/.dotfiles"

PROFILE=$(cat "$HOME/.agentic-profile" 2>/dev/null || cat "$HOME/.machine-profile" 2>/dev/null || echo "personal")
SOURCE_PROFILE="${1:-$PROFILE}"

if [ "$SOURCE_PROFILE" != "work" ] && [ "$SOURCE_PROFILE" != "personal" ]; then
    echo -e "${RED}Error: source profile must be 'work' or 'personal', got '$SOURCE_PROFILE'${NC}"
    exit 1
fi

PROFILE_DIR="$DOTFILES/private/codex/$SOURCE_PROFILE"

echo -e "${GREEN}Starting Codex configuration restore...${NC}"
echo -e "Machine profile: ${YELLOW}$PROFILE${NC}"
echo -e "Backup source: ${YELLOW}$SOURCE_PROFILE${NC}"
echo -e "Codex home: ${YELLOW}$CODEX_DIR${NC}"

if [ ! -d "$PROFILE_DIR" ]; then
    echo -e "${RED}Error: No backup found at $PROFILE_DIR${NC}"
    echo "Run codex-backup first or ensure the private/ submodule is initialized."
    exit 1
fi

if [ -f "$PROFILE_DIR/BACKUP_INFO.txt" ]; then
    echo ""
    echo -e "${YELLOW}Backup Information:${NC}"
    cat "$PROFILE_DIR/BACKUP_INFO.txt"
    echo ""
fi

read -p "Do you want to restore Codex settings from backup? (y/N) " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Restore cancelled."
    exit 0
fi

conflict_count=0
conflict_samples=()

check_conflict_file() {
    local src="$1"
    local dest="$2"
    if [ -f "$src" ] && [ -f "$dest" ]; then
        conflict_count=$((conflict_count + 1))
        if [ ${#conflict_samples[@]} -lt 5 ]; then
            conflict_samples+=("$dest")
        fi
    fi
}

check_conflict_file "$PROFILE_DIR/config.toml" "$CODEX_DIR/config.toml"
check_conflict_file "$PROFILE_DIR/AGENTS.md" "$CODEX_DIR/AGENTS.md"
check_conflict_file "$PROFILE_DIR/AGENTS.override.md" "$CODEX_DIR/AGENTS.override.md"
check_conflict_file "$PROFILE_DIR/hooks.json" "$CODEX_DIR/hooks.json"

if [ "$conflict_count" -gt 0 ]; then
    echo -e "${YELLOW}$conflict_count existing file(s) will be overwritten. Examples:${NC}"
    for sample in "${conflict_samples[@]}"; do
        echo -e "  $sample"
    done
    read -p "Continue? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Restore cancelled."
        exit 0
    fi
fi

mkdir -p "$CODEX_DIR"

restore_file() {
    local src="$1"
    local dest="$2"

    if [ -f "$src" ]; then
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        echo -e "  ✓ Restored: $(basename "$dest")"
    else
        echo -e "  ${YELLOW}⊗ Not in backup: $(basename "$dest")${NC}"
    fi
}

restore_dir() {
    local src="$1"
    local dest="$2"

    if [ -d "$src" ] && [ "$(ls -A "$src" 2>/dev/null)" ]; then
        mkdir -p "$dest"
        rsync -a "$src/" "$dest/"
        echo -e "  ✓ Restored: $(basename "$dest")/ ($(find "$src" -type f | wc -l | tr -d ' ') files)"
    else
        echo -e "  ${YELLOW}⊗ Not in backup: $(basename "$dest")/${NC}"
    fi
}

echo ""
echo "Restoring settings and global instructions..."
restore_file "$PROFILE_DIR/config.toml" "$CODEX_DIR/config.toml"
restore_file "$PROFILE_DIR/AGENTS.md" "$CODEX_DIR/AGENTS.md"
restore_file "$PROFILE_DIR/AGENTS.override.md" "$CODEX_DIR/AGENTS.override.md"
restore_file "$PROFILE_DIR/hooks.json" "$CODEX_DIR/hooks.json"
restore_dir "$PROFILE_DIR/rules" "$CODEX_DIR/rules"

echo ""
echo "Restoring user-installed skills..."
restore_dir "$PROFILE_DIR/skills" "$CODEX_DIR/skills"

echo ""
echo -e "${GREEN}✓ Restore complete!${NC}"
echo "Sign in to Codex separately; credentials were intentionally not backed up."
echo "Restart Codex to apply the restored configuration from: $SOURCE_PROFILE"
